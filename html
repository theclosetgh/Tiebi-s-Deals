<script>
  const plans = {
    MTN: [
      { gb: 1, validity: '1 Day', price: 3.5, original: 5, savings: 'Save 30%' },
      { gb: 2, validity: '3 Days', price: 6, original: 9, savings: 'Save 33%' },
      { gb: 5, validity: '7 Days', price: 13, original: 19, savings: 'Save 32%', popular: true },
      { gb: 10, validity: '30 Days', price: 22, original: 32, savings: 'Save 31%' },
      { gb: 15, validity: '30 Days', price: 30, original: 45, savings: 'Save 33%' },
      { gb: 30, validity: '30 Days', price: 55, original: 80, savings: 'Save 31%' },
    ],
    AirtelTigo: [
      { gb: 1, validity: '1 Day', price: 3, original: 4.5, savings: 'Save 33%' },
      { gb: 3, validity: '3 Days', price: 7, original: 10, savings: 'Save 30%' },
      { gb: 5, validity: '7 Days', price: 12, original: 18, savings: 'Save 33%', popular: true },
      { gb: 10, validity: '30 Days', price: 21, original: 30, savings: 'Save 30%' },
      { gb: 20, validity: '30 Days', price: 38, original: 56, savings: 'Save 32%' },
    ],
    Telecel: [
      { gb: 1, validity: '1 Day', price: 3.5, original: 5, savings: 'Save 30%' },
      { gb: 2, validity: '3 Days', price: 6.5, original: 9.5, savings: 'Save 32%' },
      { gb: 5, validity: '7 Days', price: 13, original: 19, savings: 'Save 32%', popular: true },
      { gb: 10, validity: '30 Days', price: 23, original: 33, savings: 'Save 30%' },
      { gb: 25, validity: '30 Days', price: 50, original: 73, savings: 'Save 32%' },
    ],
    Glo: [
      { gb: 1, validity: '1 Day', price: 2.8, original: 4, savings: 'Save 30%' },
      { gb: 3, validity: '3 Days', price: 6.5, original: 9.5, savings: 'Save 32%', popular: true },
      { gb: 5, validity: '7 Days', price: 11, original: 16, savings: 'Save 31%' },
      { gb: 10, validity: '30 Days', price: 20, original: 29, savings: 'Save 31%' },
    ]
  };

  let currentNetwork = 'MTN';

  function setTab(net) {
    currentNetwork = net;
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => { if(t.textContent === net) t.classList.add('active'); });
    renderPlans();
    document.getElementById('plans').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderPlans() {
    const grid = document.getElementById('plans-grid');
    const ps = plans[currentNetwork];
    grid.innerHTML = ps.map(p => `
      <div class="plan-card ${p.popular ? 'popular' : ''}" onclick="openModal('${currentNetwork}', ${p.gb}, '${p.validity}', ${p.price})">
        ${p.popular ? '<div class="popular-badge">Most popular</div>' : ''}
        <div class="plan-gb">${p.gb} <span>GB</span></div>
        <div class="plan-validity">${p.validity}</div>
        <div class="plan-price">GH₵ ${p.price.toFixed(2)}</div>
        <div class="plan-original">Was GH₵ ${p.original.toFixed(2)}</div>
        <div class="plan-savings">${p.savings}</div>
        <button class="plan-btn">Buy Now</button>
      </div>
    `).join('');
  }

  function openModal(network, gb, validity, price) {
    document.getElementById('modal-body').innerHTML = `
      <h3>Complete Purchase</h3>
      <div class="modal-plan-info">
        <div>
          <div class="label">Plan</div>
          <div style="font-weight:600; font-size:0.95rem; margin-top:2px;">${network} · ${gb}GB · ${validity}</div>
        </div>
        <div style="text-align:right">
          <div class="label">Price</div>
          <div class="value">GH₵ ${parseFloat(price).toFixed(2)}</div>
        </div>
      </div>
      <label>Phone Number to top up</label>
      <input type="tel" id="phone" placeholder="e.g. 024 123 4567" maxlength="13" />
      <label>Payment Method</label>
      <select id="payment">
        <option value="">Select payment method</option>
        <option value="momo">MTN Mobile Money</option>
        <option value="at">AirtelTigo Money</option>
        <option value="telecel">Telecel Cash</option>
        <option value="card">Debit / Credit Card</option>
      </select>
      <button class="modal-pay-btn" onclick="processPayment('${network}', ${gb}, ${price})">Pay GH₵ ${parseFloat(price).toFixed(2)} →</button>
      <div class="modal-secure">🔒 Secured payment · Instant delivery</div>
    `;
    document.getElementById('modal').classList.add('open');
  }

  function processPayment(network, gb, price) {
    const phone = document.getElementById('phone').value.trim();
    const payment = document.getElementById('payment').value;
    if (!phone || phone.length < 10) { alert('Please enter a valid phone number.'); return; }
    if (!payment) { alert('Please select a payment method.'); return; }

    document.getElementById('modal-body').innerHTML = `
      <div class="success-state">
        <div class="success-icon">✓</div>
        <h3>Order Placed!</h3>
        <p>Your <strong>${gb}GB ${network}</strong> bundle is being processed.<br>It will arrive on <strong>${phone}</strong> within 2 minutes.<br><br>You'll receive an SMS confirmation.</p>
        <button class="modal-pay-btn" style="margin-top:1.5rem;" onclick="closeModal()">Done</button>
      </div>
    `;
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('open');
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  renderPlans();
</script>
</body>
</html>
